{
  "//": "Antigravity hooks (best-effort). XÁC MINH bằng lệnh /hooks trong Antigravity. Nếu không nhận: thử đặt ở .agents/hooks.json hoặc ~/.gemini/config/hooks.json, và chỉnh 'matcher' cho khớp tên tool sửa file của bản bạn.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/format-dirty.sh\"",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/run-related-tests.sh\"",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
