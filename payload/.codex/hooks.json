{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/format-dirty.sh\"",
            "timeout": 30,
            "statusMessage": "pint + php -l (dirty files)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/run-related-tests.sh\"",
            "timeout": 180,
            "statusMessage": "phpunit (related tests)"
          }
        ]
      }
    ]
  }
}
