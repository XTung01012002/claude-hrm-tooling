# payload/Makefile.ai — ai-* targets chạy THẬT trong container hrm-api.
# Gọi: AI_FILE=source/src/.../Foo.php make -f Makefile.ai ai-lint
#      AI_TEST=tests/Unit/FooTest.php make -f Makefile.ai ai-test
# Giữ ngoài git team qua .git/info/exclude (install.sh thêm dòng "Makefile.ai").

override SHELL := /bin/sh
override .SHELLFLAGS := -eu -c

# Inputs must come from environment variables, not Make command-line variables.
# GNU Make may expand command-line values like TEST='$(shell ...)' before any
# recipe runs. Keep user-controlled values out of make's variable parser.
export AI_FILE
export AI_TEST
export AI_ROUTE_PATH

.PHONY: ai-lint ai-pint ai-pint-check ai-check ai-check-docker ai-test ai-test-docker \
        ai-php-version ai-route-list ai-migrate-status ai-about ai-event-list \
        ai-artisan-safe ai-artisan-unsafe

# --- Core targets ---
ai-lint:
	@./.claude/scripts/ai-docker.sh lint

ai-pint:
	@./.claude/scripts/ai-docker.sh pint

ai-pint-check:
	@./.claude/scripts/ai-docker.sh pint-check

ai-check-docker:
	@AI_FORCE_DOCKER=1 ./.claude/scripts/ai-docker.sh lint
	@AI_FORCE_DOCKER=1 ./.claude/scripts/ai-docker.sh pint

ai-test-docker:
	@AI_FORCE_DOCKER=1 ./.claude/scripts/ai-docker.sh test

ai-check: ai-lint ai-pint

ai-test:
	@./.claude/scripts/ai-docker.sh test

# --- Fixed read-only targets ---
ai-php-version:
	@./.claude/scripts/ai-docker.sh php-version

ai-route-list:
	@./.claude/scripts/ai-docker.sh route-list

ai-migrate-status:
	@./.claude/scripts/ai-docker.sh migrate-status

ai-about:
	@./.claude/scripts/ai-docker.sh about

ai-event-list:
	@./.claude/scripts/ai-docker.sh event-list

# --- Removed raw-command targets ---
ai-artisan-safe:
	@echo "❌ ai-artisan-safe CMD=... đã bị tắt để tránh command injection." >&2
	@echo "Dùng target cố định: ai-route-list, ai-migrate-status, ai-about, ai-event-list." >&2
	@exit 2

ai-artisan-unsafe:
	@echo "❌ ai-artisan-unsafe CMD=... đã bị tắt khỏi tooling tự động." >&2
	@echo "Nếu thật sự cần lệnh khác, người dùng chạy tay trong container sau khi kiểm tra rủi ro." >&2
	@exit 2
